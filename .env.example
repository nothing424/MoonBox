# ─────────────────────────────────────────────────────────
# AniVerse — Environment Variables
# Salin file ini ke .env.local untuk development lokal
# Tambahkan semua ke Vercel Dashboard > Settings > Env Vars
# ─────────────────────────────────────────────────────────

# ── SUPABASE (WAJIB untuk login) ──────────────────────────
# Daftar gratis di: https://supabase.com
# Ambil dari: Project > Settings > API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGc...your_anon_key_here
SUPABASE_SERVICE_KEY=eyJhbGc...your_service_role_key_here

# ── TMDB (untuk Drakor) ───────────────────────────────────
# Daftar gratis di: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# ── URL Base (sudah di-set di vercel.json, opsional lokal) ─
JIKAN_BASE_URL=https://api.jikan.moe/v4
TMDB_BASE_URL=https://api.themoviedb.org/3
TMDB_IMG_BASE=https://image.tmdb.org/t/p/w500
